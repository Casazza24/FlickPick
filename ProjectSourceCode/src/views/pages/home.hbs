<div class="home-container">
  <div class="welcome-banner">
    <h1>Discover Your Next Film</h1>
    <p>Swipe right to save, left to pass.</p>
  </div>

  <div class="card-stack">
    <div class="movie-card">
      <div class="card-poster">
        <img src="/img/home.png" alt="Movie poster placeholder" onerror="this.style.display='none'" />
        <div class="poster-fallback">🎬</div>
      </div>
      <div class="card-info">
        <h2 class="card-title">Movie Title</h2>
        <p class="card-meta">Genre &bull; Year &bull; ★ 8.5</p>
        <p class="card-synopsis">
          Movie synopsis will appear here once the API is integrated.
        </p>
      </div>
      <div class="card-actions">
        <button class="btn-pass" id="passBtn">✕ Pass</button>
        <button class="btn-save" id="saveBtn">♥ Save</button>
      </div>
    </div>
  </div>
</div>
