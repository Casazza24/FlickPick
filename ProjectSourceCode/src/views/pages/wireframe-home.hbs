<div class="wf-page">
  <div class="wf-back"><a href="/wireframes">← All Wireframes</a></div>
  <div class="wf-screen-label">Home / Swipe Page</div>

  <div class="wf-device wide">
    <!-- Header -->
    <div class="wf-bar">
      <div class="wf-logo-block"></div>
      <div class="wf-nav-links">
        <div class="wf-nav-chip"></div>
        <div class="wf-nav-chip"></div>
        <div class="wf-nav-chip accent"></div>
      </div>
    </div>

    <!-- Content -->
    <div class="wf-body centered">
      <div class="wf-welcome-block">
        <div class="wf-line w50 bold centered"></div>
        <div class="wf-line w40 thin muted centered"></div>
      </div>

      <!-- Movie card -->
      <div class="wf-movie-card">
        <div class="wf-poster-area">
          <div class="wf-poster-label">MOVIE POSTER</div>
          <div class="wf-badge">⭐ 8.4</div>
        </div>
        <div class="wf-card-info">
          <div class="wf-line w70 bold"></div>
          <div class="wf-line w50 thin muted"></div>
          <div class="wf-line w90 thin"></div>
          <div class="wf-line w80 thin"></div>
        </div>
        <div class="wf-card-actions">
          <div class="wf-action-btn pass">✕ Pass</div>
          <div class="wf-action-btn save">♥ Save</div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="wf-footer-bar">
      <div class="wf-line w50 thin muted centered"></div>
    </div>
  </div>

  <div class="wf-annotations">
    <h3>Annotations</h3>
    <ul>
      <li>Requires authentication — unauthenticated users redirected to /login</li>
      <li>Movie data fetched from TMDb API (title, genre, year, rating, synopsis, poster)</li>
      <li>Pass (✕) dismisses the card; Save (♥) adds movie to watchlist via POST /watchlist</li>
      <li>Next card loads automatically after swipe action</li>
      <li>Nav bar shows: logo, Watchlist link, Group Session link, username + Logout</li>
    </ul>
  </div>
</div>
