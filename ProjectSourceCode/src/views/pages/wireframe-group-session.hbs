<div class="wf-page">
  <div class="wf-back"><a href="/wireframes">← All Wireframes</a></div>
  <div class="wf-screen-label">Group Session Page</div>

  <div class="wf-device wide">
    <!-- Header -->
    <div class="wf-bar">
      <div class="wf-logo-block"></div>
      <div class="wf-nav-links">
        <div class="wf-nav-chip"></div>
        <div class="wf-nav-chip active"></div>
        <div class="wf-nav-chip accent"></div>
      </div>
    </div>

    <!-- Content -->
    <div class="wf-body">
      <div class="wf-section-header">
        <div class="wf-line w40 bold"></div>
        <div class="wf-line w60 thin muted"></div>
      </div>

      <!-- Create session -->
      <div class="wf-group-panel">
        <div class="wf-panel-title">CREATE SESSION</div>
        <div class="wf-field-group">
          <div class="wf-label">SESSION NAME</div>
          <div class="wf-input"></div>
        </div>
        <div class="wf-field-group">
          <div class="wf-label">INVITE FRIENDS (usernames)</div>
          <div class="wf-input tall"></div>
        </div>
        <div class="wf-btn primary">Start Session</div>
      </div>

      <!-- Divider -->
      <div class="wf-divider">OR JOIN AN EXISTING SESSION</div>

      <!-- Join session -->
      <div class="wf-group-panel">
        <div class="wf-field-group">
          <div class="wf-label">SESSION CODE</div>
          <div class="wf-input"></div>
        </div>
        <div class="wf-btn secondary">Join</div>
      </div>

      <!-- Results area (shown after session completes) -->
      <div class="wf-group-panel results">
        <div class="wf-panel-title">MATCHES — MOVIES EVERYONE LIKED</div>
        <div class="wf-match-list">
          <div class="wf-match-item">
            <div class="wf-match-poster"></div>
            <div class="wf-match-info">
              <div class="wf-line w60 thin"></div>
              <div class="wf-line w40 thin muted"></div>
            </div>
          </div>
          <div class="wf-match-item">
            <div class="wf-match-poster"></div>
            <div class="wf-match-info">
              <div class="wf-line w50 thin"></div>
              <div class="wf-line w35 thin muted"></div>
            </div>
          </div>
          <div class="wf-match-item">
            <div class="wf-match-poster"></div>
            <div class="wf-match-info">
              <div class="wf-line w70 thin"></div>
              <div class="wf-line w40 thin muted"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="wf-footer-bar">
      <div class="wf-line w50 thin muted centered"></div>
    </div>
  </div>

  <div class="wf-annotations">
    <h3>Annotations</h3>
    <ul>
      <li>User creates a session and invites friends by username</li>
      <li>Each participant swipes through movies independently in real time</li>
      <li>Results panel shows movies that ALL participants saved</li>
      <li>Session can also be joined via a share code</li>
      <li>Requires authentication</li>
    </ul>
  </div>
</div>
