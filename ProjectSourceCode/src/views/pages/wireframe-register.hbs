<div class="wf-page">
  <div class="wf-back"><a href="/wireframes">← All Wireframes</a></div>
  <div class="wf-screen-label">Register Page</div>

  <div class="wf-device">
    <!-- Header -->
    <div class="wf-bar">
      <div class="wf-logo-block"></div>
    </div>

    <!-- Content -->
    <div class="wf-body centered">
      <div class="wf-form-card">
        <div class="wf-heading-block">
          <div class="wf-line w60"></div>
          <div class="wf-line w50 thin muted"></div>
        </div>

        <div class="wf-field-group">
          <div class="wf-label">USERNAME</div>
          <div class="wf-input"></div>
        </div>
        <div class="wf-field-group">
          <div class="wf-label">EMAIL</div>
          <div class="wf-input"></div>
        </div>
        <div class="wf-field-group">
          <div class="wf-label">PASSWORD</div>
          <div class="wf-input"></div>
        </div>

        <div class="wf-btn primary">Create Account</div>

        <div class="wf-switch-text">
          <div class="wf-line w70 thin muted centered"></div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="wf-footer-bar">
      <div class="wf-line w50 thin muted centered"></div>
    </div>
  </div>

  <div class="wf-annotations">
    <h3>Annotations</h3>
    <ul>
      <li>Username and email must be unique — error shown inline if taken</li>
      <li>Password is hashed server-side before storage</li>
      <li>Link to /login for existing users</li>
      <li>Redirects to /login on successful registration</li>
    </ul>
  </div>
</div>
