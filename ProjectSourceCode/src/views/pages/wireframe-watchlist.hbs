<div class="wf-page">
  <div class="wf-back"><a href="/wireframes">← All Wireframes</a></div>
  <div class="wf-screen-label">Watchlist Page</div>

  <div class="wf-device wide">
    <!-- Header -->
    <div class="wf-bar">
      <div class="wf-logo-block"></div>
      <div class="wf-nav-links">
        <div class="wf-nav-chip active"></div>
        <div class="wf-nav-chip"></div>
        <div class="wf-nav-chip accent"></div>
      </div>
    </div>

    <!-- Content -->
    <div class="wf-body">
      <div class="wf-section-header">
        <div class="wf-line w30 bold"></div>
        <div class="wf-line w20 thin muted"></div>
      </div>

      <!-- Movie grid -->
      <div class="wf-movie-grid">
        {{#each [1,2,3,4,5,6]}}
        <div class="wf-grid-card">
          <div class="wf-grid-poster">POSTER</div>
          <div class="wf-grid-info">
            <div class="wf-line w80 thin"></div>
            <div class="wf-line w50 thin muted"></div>
          </div>
          <div class="wf-remove-btn">✕</div>
        </div>
        {{/each}}
        <!-- Static 6 cards since Handlebars doesn't support #each on literals -->
        <div class="wf-grid-card">
          <div class="wf-grid-poster">POSTER</div>
          <div class="wf-grid-info">
            <div class="wf-line w80 thin"></div>
            <div class="wf-line w50 thin muted"></div>
          </div>
          <div class="wf-remove-btn">✕</div>
        </div>
        <div class="wf-grid-card">
          <div class="wf-grid-poster">POSTER</div>
          <div class="wf-grid-info">
            <div class="wf-line w80 thin"></div>
            <div class="wf-line w50 thin muted"></div>
          </div>
          <div class="wf-remove-btn">✕</div>
        </div>
        <div class="wf-grid-card">
          <div class="wf-grid-poster">POSTER</div>
          <div class="wf-grid-info">
            <div class="wf-line w80 thin"></div>
            <div class="wf-line w50 thin muted"></div>
          </div>
          <div class="wf-remove-btn">✕</div>
        </div>
        <div class="wf-grid-card">
          <div class="wf-grid-poster">POSTER</div>
          <div class="wf-grid-info">
            <div class="wf-line w80 thin"></div>
            <div class="wf-line w50 thin muted"></div>
          </div>
          <div class="wf-remove-btn">✕</div>
        </div>
        <div class="wf-grid-card">
          <div class="wf-grid-poster">POSTER</div>
          <div class="wf-grid-info">
            <div class="wf-line w80 thin"></div>
            <div class="wf-line w50 thin muted"></div>
          </div>
          <div class="wf-remove-btn">✕</div>
        </div>
        <div class="wf-grid-card">
          <div class="wf-grid-poster">POSTER</div>
          <div class="wf-grid-info">
            <div class="wf-line w80 thin"></div>
            <div class="wf-line w50 thin muted"></div>
          </div>
          <div class="wf-remove-btn">✕</div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="wf-footer-bar">
      <div class="wf-line w50 thin muted centered"></div>
    </div>
  </div>

  <div class="wf-annotations">
    <h3>Annotations</h3>
    <ul>
      <li>Shows all movies the user has saved via the swipe screen</li>
      <li>Each card displays: movie poster, title, year/genre</li>
      <li>✕ button removes the movie from watchlist via DELETE /watchlist/:id</li>
      <li>Empty state shown with a prompt to go discover movies if watchlist is empty</li>
      <li>Requires authentication</li>
    </ul>
  </div>
</div>
