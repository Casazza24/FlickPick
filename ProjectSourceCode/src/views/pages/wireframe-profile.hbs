<div class="wf-page">
  <div class="wf-back"><a href="/wireframes">← All Wireframes</a></div>
  <div class="wf-screen-label">Profile Page</div>

  <div class="wf-device wide">
    <!-- Header -->
    <div class="wf-bar">
      <div class="wf-logo-block"></div>
      <div class="wf-nav-links">
        <div class="wf-nav-chip"></div>
        <div class="wf-nav-chip"></div>
        <div class="wf-nav-chip active accent"></div>
      </div>
    </div>

    <!-- Content -->
    <div class="wf-body">
      <!-- Avatar + name -->
      <div class="wf-profile-header">
        <div class="wf-avatar"></div>
        <div class="wf-profile-info">
          <div class="wf-line w40 bold"></div>
          <div class="wf-line w50 thin muted"></div>
        </div>
      </div>

      <!-- Stats row -->
      <div class="wf-stats-row">
        <div class="wf-stat-box">
          <div class="wf-stat-num"></div>
          <div class="wf-stat-label">Saved</div>
        </div>
        <div class="wf-stat-box">
          <div class="wf-stat-num"></div>
          <div class="wf-stat-label">Passed</div>
        </div>
        <div class="wf-stat-box">
          <div class="wf-stat-num"></div>
          <div class="wf-stat-label">Sessions</div>
        </div>
      </div>

      <!-- Favorite genres -->
      <div class="wf-profile-section">
        <div class="wf-panel-title">TOP GENRES</div>
        <div class="wf-genre-chips">
          <div class="wf-genre-chip"></div>
          <div class="wf-genre-chip"></div>
          <div class="wf-genre-chip"></div>
          <div class="wf-genre-chip"></div>
        </div>
      </div>

      <!-- Recent saves -->
      <div class="wf-profile-section">
        <div class="wf-panel-title">RECENTLY SAVED</div>
        <div class="wf-recent-list">
          <div class="wf-recent-item">
            <div class="wf-recent-poster"></div>
            <div class="wf-line w50 thin"></div>
          </div>
          <div class="wf-recent-item">
            <div class="wf-recent-poster"></div>
            <div class="wf-line w60 thin"></div>
          </div>
          <div class="wf-recent-item">
            <div class="wf-recent-poster"></div>
            <div class="wf-line w40 thin"></div>
          </div>
        </div>
      </div>

      <div class="wf-btn secondary">Edit Profile</div>
    </div>

    <!-- Footer -->
    <div class="wf-footer-bar">
      <div class="wf-line w50 thin muted centered"></div>
    </div>
  </div>

  <div class="wf-annotations">
    <h3>Annotations</h3>
    <ul>
      <li>Avatar placeholder — profile picture upload in future iteration</li>
      <li>Stats (Saved, Passed, Sessions) derived from database queries</li>
      <li>Top Genres calculated from swipe history via genre tags on saved movies</li>
      <li>Recently Saved links to watchlist entries</li>
      <li>Requires authentication</li>
    </ul>
  </div>
</div>
